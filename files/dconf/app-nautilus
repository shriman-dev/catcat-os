[org/gnome/nautilus/icon-view]
captions=['size', 'date_modified', 'none']
default-zoom-level='medium'

[org/gnome/nautilus/list-view]
default-column-order=['size', 'name', 'type', 'owner', 'mime_type', 'where', 'date_modified', 'date_modified_with_time', 'date_accessed', 'date_created', 'recency', 'permissions', 'group', 'starred']
default-visible-columns=['name', 'size', 'date_modified_with_time', 'permissions', 'group']
default-zoom-level='medium'
use-tree-view=true

[org/gnome/nautilus/preferences]
click-policy='double'
default-folder-viewer='icon-view'
migrated-gtk-settings=true
search-filter-time-type='last_modified'
show-create-link=true
show-delete-permanently=true
show-directory-item-counts='always'
show-hidden-files=true
type-ahead-search=true

