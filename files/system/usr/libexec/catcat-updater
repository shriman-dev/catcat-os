#!/bin/bash

FLATPAK_APPS_TO_UPDATE_SOLEY=(
  "io.gitlab.librewolf-community"
  "com.brave.Browser"
  "org.gnome.Epiphany"
)

for APP in "${FLATPAK_APPS_TO_UPDATE_SOLEY[@]}"; do
  /usr/bin/flatpak update --assumeyes --noninteractive "$APP"
done

# two weeks = 1209600
# update system if system has not been updated for two weeks

if [[ $(stat -c "%Y" /etc/catcat-os/last-update) -lt $(( $(date +%s) - 1209600 )) ]]; then
  /usr/bin/flatpak update --assumeyes --noninteractive
  /usr/bin/flatpak uninstall --unused

  [[ ! $(id -u) -eq 0 ]] && command -v nix-env && nix-channel --update && nix-env -b --upgrade
  [[ ! $(id -u) -eq 0 ]] && command -v nix-env && nix-store --optimise && nix-collect-garbage

  [[ $(id -u) -eq 0 ]] && /usr/bin/ublue-update
  rpm-ostree cleanup -b ; ostree prune

  [[ $(id -u) -eq 0 ]] && echo $(date "+%a %b %d %H:%M:%S %Y") > /etc/catcat-os/last-update

  notify-desktop "Automatic Bi-Weekly Update is done."
fi

