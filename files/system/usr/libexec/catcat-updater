#!/bin/bash

FLATPAK_APPS_TO_UPDATE_SOLEY=(
  "io.gitlab.librewolf-community"
  "com.brave.Browser"
  "org.gnome.Epiphany"
  "org.torproject.torbrowser-launcher"
)

for APP in "${FLATPAK_APPS_TO_UPDATE_SOLEY[@]}"; do
  /usr/bin/flatpak update --assumeyes --noninteractive "$APP"
done

# two weeks = 1209600
# one week = 604800

# update if system is one weeks old
if [[ $(stat -c "%Y" /etc/catcat-os/last-auto-update) -lt $(( $(date +%s) - 604800 )) ]]; then
    /usr/bin/notify-send "Automatic Weekly Update has Started."
    /usr/bin/flatpak update --assumeyes --noninteractive
    /usr/bin/flatpak uninstall --unused

    if [[ ! $(id -u) -eq 0 ]] && command -v nix-env; then
      nix-channel --update && nix-env -b --upgrade
      nix-store --optimise && nix-collect-garbage
    fi

    if [[ $(id -u) -eq 0 ]] ; then
      /usr/bin/fwupdmgr refresh -y --force && /usr/bin/fwupdmgr -y update
    fi

    if [[ $(id -u) -eq 0 ]] && [[ $(stat -c "%Y" /etc/catcat-os/update_sha) -lt $(( $(date +%s) - 604800 )) ]]; then
      /usr/bin/rpm-ostree upgrade && UPDATE_SUCCESSFUL=1
      /usr/bin/rpm-ostree cleanup -b ; /usr/bin/ostree prune
    fi

    echo $(date "+%a %b %d %H:%M:%S %Y") > /etc/catcat-os/last-auto-update
    /usr/bin/notify-send "Automatic Weekly Update is done."
fi

