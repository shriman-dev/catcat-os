#!/bin/bash
shopt -s extglob

if [ ! -f '~/.local/share/catcat-os/first-boot' ]; then
  # default configs for user home
  cp -Prf /etc/skel/* ~/


  # desktop files
  mkdir -p ~/.local/share/applications
  if flatpak list | grep -i "freetube"; then
  sed 's|^Icon=.*|Icon=/usr/share/icons/crafted/yt2.svg|' /var/lib/flatpak/exports/share/applications/io.freetubeapp.FreeTube.desktop > ~/.local/share/applications/io.freetubeapp.FreeTube.desktop
  fi

  if flatpak list | grep -i "librewolf"; then
  sed 's|^Icon=.*|Icon=firefox|' /var/lib/flatpak/exports/share/applications/io.gitlab.librewolf-community.desktop > ~/.local/share/applications/io.gitlab.librewolf-community.desktop
  fi

  if flatpak list | grep -i "ArmCord"; then
  sed 's|^Icon=.*|Icon=discord|' /var/lib/flatpak/exports/share/applications/xyz.armcord.ArmCord.desktop > ~/.local/share/applications/xyz.armcord.ArmCord.desktop
  fi

  mkdir -p ~/.local/share/catcat-os
  echo 'first boot' > ~/.local/share/catcat-os/first-boot

fi

# default configs for user home
rsync -vrlu --ignore-existing /etc/skel/* ~/
#cp -Prfu /etc/skel/.local/share/gnome-shell/extensions/* ~/.local/share/gnome-shell/extensions/

dconf write /org/gnome/shell/extensions/burn-my-windows/active-profile "'$HOME/.config/burn-my-windows/profiles/1679372508290696.conf'"


# theme flatpak apps
  grep 'devices=!all' $HOME/.local/share/flatpak/overrides/global || sh -c "echo '[Context]
devices=!all;
filesystems=!host;!host-etc;!host-os;~/.themes:ro;~/.icons:ro;xdg-data/icons:ro;xdg-data/themes:ro;xdg-data/fonts:ro;xdg-config/gtk-3.0:ro;xdg-config/gtk-4.0:ro;xdg-config/Kvantum:ro;xdg-config/qt5ct:ro;

[Environment]
QT_STYLE_OVERRIDE=kvantum
' > $HOME/.local/share/flatpak/overrides/global"

mkdir -p ~/.local/share/themes
mkdir -p ~/.local/share/icons
mkdir -p ~/.local/share/fonts

ln -srfTv $HOME/.local/share/icons $HOME/.icons
ln -srfTv $HOME/.local/share/themes $HOME/.themes

find /usr/share/themes/ -maxdepth 1 -mindepth 1 -type d -name '*Catppuccin*' -exec cp -Prfu {} ~/.local/share/themes \;
find /usr/share/themes/ -maxdepth 1 -mindepth 1 -type d -name '*Lavanda*' -exec cp -Prfu {} ~/.local/share/themes \;

# set folder icons
gio set ~/Me metadata::custom-icon-name "user-home"
gio set ~/Me/Backups metadata::custom-icon-name "folder-backup"
gio set ~/Me/Devel metadata::custom-icon-name "folder-code"
gio set ~/Me/Ebooks metadata::custom-icon-name "folder-books"
gio set ~/Me/Games metadata::custom-icon-name "folder-games"
gio set ~/Me/Notes metadata::custom-icon-name "folder-notes"
gio set ~/Me/Scripts metadata::custom-icon-name "folder-script"
gio set ~/Me/Secure metadata::custom-icon-name "folder-locked"
gio set ~/Me/Syncthing metadata::custom-icon-name "folder-syncthing"

gtk-update-icon-cache
gtk4-update-icon-cache














