<style-scheme id="catpuccin-mocha" _name="Catpuccin Mocha" version="1.0">
  <author>GtkSourceView team</author>
  <_description>Catpuccin color scheme</_description>

  <!-- The scheme tries to look like the default GVim scheme,
       since it is also what the hardwired GtkSourceView 1 color
       scheme did -->

  <!-- Palette -->
  <color name="white"      value="#cdd6f4"/>
  <color name="blue"       value="#b6c0ff"/>
  <color name="magenta"    value="#f5c2e7"/>
  <color name="violet"     value="#c28fff"/>
  <color name="cyan"       value="#aafff1"/>
  <color name="gray"       value="#6c7086"/>
  <color name="green"      value="#c1ffbc"/>
  <color name="bordeaux"   value="#ff6868"/>
  <color name="red"        value="#eba0ac"/>
  <color name="yellow"     value="#ffe8b5"/>
  <color name="purple"     value="#d1aaff"/>
  <color name="orange"     value="#fab387"/>

  <!-- Global Settings -->
  <style name="line-numbers"                background="#cdd6f4"/>
  <style name="current-line"                background="#373754"/>
  <style name="current-line-number"         background="#cdd6f4"/>
  <style name="draw-spaces"                 foreground="#8f94ad"/>
  <style name="background-pattern"          background="#181825"/>

  <!-- Bracket Matching -->
  <style name="bracket-match"               foreground="yellow"/>
  <style name="bracket-mismatch"            foreground="#cdd6f4" background="#ff9393" bold="true" />

  <!-- Right Margin -->
  <style name="right-margin"                foreground="#cdd6f4" background="#11111b"/>

  <!-- Search Matching -->
  <style name="search-match"                foreground="#181825" background="#89b4fa"/>

  <!-- Comments -->
  <style name="def:comment"                 foreground="gray"/>
  <style name="def:shebang"                 foreground="gray" bold="true"/>
  <style name="def:doc-comment-element"     italic="true"/>

  <!-- Constants -->
  <style name="def:constant"                foreground="green"/>
  <style name="def:string"	                foreground="green" />
  <style name="def:special-char"            foreground="blue"/>

  <!-- Identifiers -->
  <style name="def:identifier"              foreground="blue"/>

  <!-- Statements -->
  <style name="def:statement"               foreground="#74c7ec" bold="true"/>

  <!-- Types -->
  <style name="def:type"                    foreground="red" bold="true"/>

  <!-- Markup -->
  <style name="def:emphasis"                italic="true"/>
  <style name="def:strong-emphasis"         foreground="yellow" bold="true"/>
  <style name="def:inline-code"             foreground="green"/>
  <style name="def:insertion"               underline="single"/>
  <style name="def:deletion"                strikethrough="true"/>
  <style name="def:link-text"               foreground="#f5e0dc"/>
  <style name="def:link-symbol"             foreground="blue" bold="true"/>
  <style name="def:link-destination"        italic="true" underline="single"/>
  <style name="def:heading"                 foreground="#94e2d5" bold="true"/>
  <style name="def:thematic-break"          foreground="green" bold="true"/>
  <style name="def:preformatted-section"    foreground="cyan"/>
  <style name="def:list-marker"             foreground="#94e2d5" bold="true"/>

  <!-- Others -->
  <style name="def:preprocessor"            foreground="#94e2d5"/>
  <style name="def:error"                   background="red" bold="true"/>
  <style name="def:warning"                 background="yellow"/>
  <style name="def:note"                    foreground="blue" background="yellow" bold="true"/>
  <style name="def:net-address"             italic="true" underline="single"/>

  <!-- Heading styles, uncomment to enable -->
  <!--
  <style name="def:heading0"                scale="5.0"/>
  <style name="def:heading1"                scale="2.5"/>
  <style name="def:heading2"                scale="2.0"/>
  <style name="def:heading3"                scale="1.7"/>
  <style name="def:heading4"                scale="1.5"/>
  <style name="def:heading5"                scale="1.3"/>
  <style name="def:heading6"                scale="1.2"/>
  -->

  <!-- Language specific styles -->
  <style name="diff:added-line"             foreground="#74c7ec"/>
  <style name="diff:removed-line"           foreground="#89b4fa"/>
  <style name="diff:changed-line"           use-style="def:preprocessor"/>
  <style name="diff:special-case"           use-style="def:constant"/>
  <style name="diff:location"               use-style="def:statement"/>
  <style name="diff:diff-file"              use-style="def:type"/>

  <style name="xml:tags"                    foreground="cyan"/>
  <style name="xml:attribute-name"          foreground="violet"/>
  <style name="xml:namespace"               foreground="green" bold="true"/>

  <style name="js:built-in-constructor"     use-style="def:identifier"/>

  <style name="latex:display-math"          foreground="#89b4fa"/>
  <style name="latex:command"               foreground="#89dceb" bold="true"/>
  <style name="latex:include"               use-style="def:preprocessor"/>

  <style name="sh:variable"                 foreground="red" bold="true"/>

  <!-- legacy styles for old lang files -->
  <style name="Others"                      foreground="#89dceb" bold="true"/>
  <style name="Others 2"                    foreground="#74c7ec"/>
  <style name="Others 3"                    foreground="#89b4fa"/>

</style-scheme>
